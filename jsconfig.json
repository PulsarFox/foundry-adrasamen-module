{
	"compilerOptions": {
		"module": "ES2022",
		"target": "ES2022",
		"moduleResolution": "node",
		"allowSyntheticDefaultImports": true,
		"esModuleInterop": true,
		"allowJs": true,
		"checkJs": true,
		"strict": false,
		"noImplicitAny": false,
		"skipLibCheck": true,
		"baseUrl": "./",
		"paths": {
			"@dnd5e/*": ["../../systems/dnd5e/module/*"],
			"@dnd5e/documents": [
				"../../systems/dnd5e/module/documents/_module.mjs"
			],
			"@dnd5e/documents/*": ["../../systems/dnd5e/module/documents/*"],
			"@dnd5e/config": ["../../systems/dnd5e/module/config.mjs"],
			"@dnd5e/utils": ["../../systems/dnd5e/module/utils.mjs"],
			"@dnd5e": ["../../systems/dnd5e/dnd5e.mjs"],
			"@foundry/*": [
				"../../../../../../../../Program Files/Foundry Virtual Tabletop/resources/app/common/*"
			],
			"@foundry/documents": [
				"../../../../../../../../Program Files/Foundry Virtual Tabletop/resources/app/common/documents/_module.mjs"
			]
		},
		"typeRoots": ["../../systems/dnd5e/module", "../../systems/dnd5e"]
	},
	"include": [
		"scripts/**/*",
		"../../systems/dnd5e/module/**/*",
		"../../../../../../../../Program Files/Foundry Virtual Tabletop/resources/app/common/**/*"
	],
	"exclude": ["node_modules", "packs", "lang"]
}
