{
	"compilerOptions": {
		"module": "ES2022",
		"target": "ES2022",
		"checkJs": false,
		"allowJs": true,
		"strict": false,
		"moduleResolution": "node",
		"types": ["./foundry.d.ts", "foundry/client/global.d.mts"],
		"paths": {
			"@client/*": ["./foundry/client/*"],
			"@common/*": ["./foundry/common/*"],
			"@dnd5e/*": ["../../systems/dnd5e/*"]
		}
	},
	"exclude": ["node_modules", "**/node_modules/*"],
	"include": [
		"**/*.mjs",
		"**/*.js",
		"foundry.d.ts",
		"foundry/client/client.mjs",
		"foundry/client/global.d.mts",
		"foundry/common/primitives/global.d.mts",
		"../../systems/dnd5e/**/*.mjs"
	],
	"typeAcquisition": {
		"include": ["jquery"]
	}
}
