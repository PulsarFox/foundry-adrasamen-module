{{!-- Nexus Quadralithe Configuration Partial --}}
<fieldset>
    <legend>{{ localize "ADRASAMEN.NexusConfiguration" }}</legend>
    <p class="hint">{{ localize "ADRASAMEN.NexusEffectsHint" }}</p>

    <div class="form-group">
        <label>{{ localize "ADRASAMEN.MaxManaBonus" }}</label>
        <div class="form-fields">
            <input type="text" name="system.quadralithe.effects.maxManaBonus"
                value="{{system.quadralithe.effects.maxManaBonus}}" placeholder="0"
                title="{{ localize 'ADRASAMEN.FormulaTooltip' }}">
        </div>
    </div>

    <div class="form-group">
        <label>{{ localize "ADRASAMEN.CostReduction" }}</label>
        <div class="form-fields">
            <input type="text" name="system.quadralithe.effects.costReduction"
                value="{{system.quadralithe.effects.costReduction}}" placeholder="0"
                title="{{ localize 'ADRASAMEN.FormulaTooltip' }}">
        </div>
    </div>
</fieldset>