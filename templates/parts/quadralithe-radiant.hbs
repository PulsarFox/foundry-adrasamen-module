{{!-- Radiant Quadralithe Configuration Partial --}}
<div class="quadralithe-config radiant-config">
    <h3>{{ localize "ADRASAMEN.RadiantConfiguration" }}</h3>
    <p class="hint">{{ localize "ADRASAMEN.RadiantEffectsHint" }}</p>

    <div class="form-group">
        <label for="formula-bonus">{{ localize "ADRASAMEN.FormulaBonus" }}</label>
