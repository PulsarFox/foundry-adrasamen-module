{{!-- Mana Points Advancement Flow Template --}}

<div class="standard-form">
  <div class="breakdown form-group split-group">
    <div class="form-fields">
      {{!-- Selected Mana Increase --}}
      {{#if manual}}
      <div class="form-group label-top">
        <label>{{ localize "ADRASAMEN.ADVANCEMENT.ManaPoints.Roll" }}</label>
        <div class="form-fields">
          <input class="roll-result" type="number" name="value" value="{{ data.value }}">
        </div>
      </div>
      {{else}}
      <div class="form-group label-top">
        <label>{{ localize "ADRASAMEN.ADVANCEMENT.ManaPoints.Average" }}</label>
        <span>{{ mana.average }}</span>
      </div>
      {{/if}}

      {{!-- Affinity Level Bonus --}}
      {{#if mana.formula}}
      <span class="separator">using</span>
      <div class="form-group label-top">
        <label>{{ localize "ADRASAMEN.ManaPointFormula" }}</label>
        <span class="formula-display">{{ mana.formula }}</span>
      </div>
      {{/if}}

      <span class="separator">=</span>

      {{!-- Final Mana Gain --}}
      <div class="form-group label-top">
        <label>{{ localize "ADRASAMEN.ADVANCEMENT.ManaPoints.Final" }}</label>
        <span>{{ mana.total }}</span>
      </div>
    </div>

    {{#if manual}}
    <button class="roll-button dice-button" type="button" data-action="rollManaPoints" data-tooltip
      aria-label="{{ localize 'DND5E.Roll' }} {{ mana.formula }}">
      <i class="fas fa-dice-d20"></i>
    </button>
    {{/if}}
  </div>

  <fieldset>
    <legend>{{ localize "ADRASAMEN.ADVANCEMENT.ManaPoints.Options" }}</legend>
    <div class="form-group">
      <label for="{{ partId }}-useAverage">{{ localize "ADRASAMEN.ADVANCEMENT.ManaPoints.TakeAverage" }}</label>
      <div class="form-fields">
        <input type="checkbox" name="useAverage" id="{{ partId }}-useAverage" {{ checked data.useAverage }}>
      </div>
    </div>
  </fieldset>
</div>