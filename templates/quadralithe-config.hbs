{{!-- Quadralithe Configuration Template --}}
<div class="quadralithe-config sheet-section">
    <h3>{{ localize "ADRASAMEN.QuadralitheConfiguration" }}</h3>

    {{!-- Morphos Configuration --}}
    {{#if (eq system.quadralithe.type "morphos")}}
    <div class="morphos-effects">
        <h4>{{ localize "ADRASAMEN.MorphosEffects" }}</h4>
        <p class="hint">{{ localize "ADRASAMEN.MorphosEffectsHint" }}</p>

        <div class="affinity-cost-grid">
            <!-- Row 1: Water, Air, Earth -->
            <div class="affinity-cost-item">
                <i class="fas fa-tint" style="color: var(--dnd5e-color-blue)"
                    title="{{localize 'ADRASAMEN.Affinity.water'}}"></i>
                <input type="text" name="quadralithe.effects.affinityBonus.water"
                    value="{{system.quadralithe.effects.affinityBonus.water}}" placeholder="0"
                    title="{{ localize 'ADRASAMEN.FormulaTooltip' }}" class="affinity-bonus-input">
            </div>
            <div class="affinity-cost-item">
                <i class="fas fa-wind" style="color: var(--dnd5e-color-faint)"
                    title="{{localize 'ADRASAMEN.Affinity.air'}}"></i>
                <input type="text" name="quadralithe.effects.affinityBonus.air"
                    value="{{system.quadralithe.effects.affinityBonus.air}}" placeholder="0"
                    title="{{ localize 'ADRASAMEN.FormulaTooltip' }}" class="affinity-bonus-input">
            </div>
            <div class="affinity-cost-item">
                <i class="fas fa-mountain" style="color: var(--dnd5e-color-olive)"
                    title="{{localize 'ADRASAMEN.Affinity.earth'}}"></i>
                <input type="text" name="quadralithe.effects.affinityBonus.earth"
                    value="{{system.quadralithe.effects.affinityBonus.earth}}" placeholder="0"
                    title="{{ localize 'ADRASAMEN.FormulaTooltip' }}" class="affinity-bonus-input">
            </div>

            <!-- Row 2: Fire, Ice, Light -->
            <div class="affinity-cost-item">
                <i class="fas fa-fire" style="color: var(--dnd5e-color-red)"
                    title="{{localize 'ADRASAMEN.Affinity.fire'}}"></i>
                <input type="text" name="quadralithe.effects.affinityBonus.fire"
                    value="{{system.quadralithe.effects.affinityBonus.fire}}" placeholder="0"
                    title="{{ localize 'ADRASAMEN.FormulaTooltip' }}" class="affinity-bonus-input">
            </div>
            <div class="affinity-cost-item">
                <i class="far fa-snowflake" style="color: var(--dnd5e-color-faint)"
                    title="{{localize 'ADRASAMEN.Affinity.ice'}}"></i>
                <input type="text" name="quadralithe.effects.affinityBonus.ice"
                    value="{{system.quadralithe.effects.affinityBonus.ice}}" placeholder="0"
                    title="{{ localize 'ADRASAMEN.FormulaTooltip' }}" class="affinity-bonus-input">
            </div>
            <div class="affinity-cost-item">
                <i class="fas fa-sun" style="color: var(--dnd5e-color-gold)"
                    title="{{localize 'ADRASAMEN.Affinity.light'}}"></i>
                <input type="text" name="quadralithe.effects.affinityBonus.light"
                    value="{{system.quadralithe.effects.affinityBonus.light}}" placeholder="0"
                    title="{{ localize 'ADRASAMEN.FormulaTooltip' }}" class="affinity-bonus-input">
            </div>

            <!-- Row 3: Shadow, Mind, Arcane -->
            <div class="affinity-cost-item">
                <i class="fas fa-moon" style="color: var(--dnd5e-color-dark)"
                    title="{{localize 'ADRASAMEN.Affinity.shadow'}}"></i>
                <input type="text" name="quadralithe.effects.affinityBonus.shadow"
                    value="{{system.quadralithe.effects.affinityBonus.shadow}}" placeholder="0"
                    title="{{ localize 'ADRASAMEN.FormulaTooltip' }}" class="affinity-bonus-input">
            </div>
            <div class="affinity-cost-item">
                <i class="fas fa-brain" style="color: var(--dnd5e-color-tan)"
                    title="{{localize 'ADRASAMEN.Affinity.mind'}}"></i>
                <input type="text" name="quadralithe.effects.affinityBonus.mind"
                    value="{{system.quadralithe.effects.affinityBonus.mind}}" placeholder="0"
                    title="{{ localize 'ADRASAMEN.FormulaTooltip' }}" class="affinity-bonus-input">
            </div>
            <div class="affinity-cost-item">
                <i class="fas fa-magic" style="color: var(--dnd5e-color-crimson)"
                    title="{{localize 'ADRASAMEN.Affinity.arcane'}}"></i>
                <input type="text" name="quadralithe.effects.affinityBonus.arcane"
                    value="{{system.quadralithe.effects.affinityBonus.arcane}}" placeholder="0"
                    title="{{ localize 'ADRASAMEN.FormulaTooltip' }}" class="affinity-bonus-input">
            </div>
        </div>
    </div>
    {{/if}}

    {{!-- Nexus Configuration --}}
    {{#if (eq system.quadralithe.type "nexus")}}
    <div class="nexus-effects">
        <h4>{{ localize "ADRASAMEN.NexusEffects" }}</h4>
        <p class="hint">{{ localize "ADRASAMEN.NexusEffectsHint" }}</p>

        <div class="form-group">
            <label for="max-mana-bonus">{{ localize "ADRASAMEN.MaxManaBonus" }}</label>
            <input type="text" id="max-mana-bonus" name="quadralithe.effects.maxManaBonus"
                value="{{system.quadralithe.effects.maxManaBonus}}" placeholder="0"
                title="{{ localize 'ADRASAMEN.FormulaTooltip' }}" />
        </div>

        <div class="form-group">
            <label for="cost-reduction">{{ localize "ADRASAMEN.CostReduction" }}</label>
            <input type="text" id="cost-reduction" name="quadralithe.effects.costReduction"
                value="{{system.quadralithe.effects.costReduction}}" placeholder="0"
                title="{{ localize 'ADRASAMEN.FormulaTooltip' }}" />
        </div>
    </div>
    {{/if}}

    {{!-- Radiant Configuration --}}
    {{#if (eq system.quadralithe.type "radiant")}}
    <div class="radiant-effects">
        <h4>{{ localize "ADRASAMEN.RadiantEffects" }}</h4>
        <p class="hint">{{ localize "ADRASAMEN.RadiantEffectsHint" }}</p>

        <div class="form-group">
            <label for="formula-bonus">{{ localize "ADRASAMEN.FormulaBonus" }}</label>
            <input type="text" id="formula-bonus" name="quadralithe.effects.formulaBonus"
                value="{{system.quadralithe.effects.formulaBonus}}" placeholder="0"
                title="{{ localize 'ADRASAMEN.FormulaTooltip' }}" />
        </div>
    </div>
    {{/if}}

    {{!-- Drain Configuration --}}
    {{#if (eq system.quadralithe.type "drain")}}
    <div class="drain-effects">
        <h4>{{ localize "ADRASAMEN.DrainEffects" }}</h4>
        <p class="hint">{{ localize "ADRASAMEN.DrainEffectsHint" }}</p>

        <div class="form-group">
            <label for="mana-generation">{{ localize "ADRASAMEN.ManaGeneration" }}</label>
            <input type="text" id="mana-generation" name="quadralithe.effects.manaGeneration"
                value="{{system.quadralithe.effects.manaGeneration}}" placeholder="1"
                title="{{ localize 'ADRASAMEN.FormulaTooltip' }}" />
        </div>

        <fieldset class="range-config">
            <legend>{{ localize "ADRASAMEN.Range" }}</legend>

            <div class="form-group">
                <label for="drain-range-value">{{ localize "ADRASAMEN.RangeValue" }}</label>
                <input type="text" id="drain-range-value" name="quadralithe.effects.range.value"
                    value="{{system.quadralithe.effects.range.value}}" placeholder="0" />
            </div>

            <div class="form-group">
                <label for="drain-range-units">{{ localize "ADRASAMEN.RangeUnits" }}</label>
                <select id="drain-range-units" name="quadralithe.effects.range.units">
                    <option value="m" {{#if (eq system.quadralithe.effects.range.units "m" )}}selected{{/if}}>
                        {{ localize "DND5E.Meters" }}
                    </option>
                    <option value="ft" {{#if (eq system.quadralithe.effects.range.units "ft" )}}selected{{/if}}>
                        {{ localize "DND5E.Feet" }}
                    </option>
                    <option value="mi" {{#if (eq system.quadralithe.effects.range.units "mi" )}}selected{{/if}}>
                        {{ localize "DND5E.Miles" }}
                    </option>
                </select>
            </div>

            <div class="form-group">
                <label for="drain-range-special">{{ localize "ADRASAMEN.RangeSpecial" }}</label>
                <input type="text" id="drain-range-special" name="quadralithe.effects.range.special"
                    value="{{system.quadralithe.effects.range.special}}"
                    placeholder="{{ localize 'ADRASAMEN.RangeSpecialPlaceholder' }}" />
            </div>
        </fieldset>

        <fieldset class="target-config">
            <legend>{{ localize "ADRASAMEN.TargetConfiguration" }}</legend>

            <div class="target-affects">
                <h5>{{ localize "ADRASAMEN.TargetAffects" }}</h5>

                <div class="form-group">
                    <label for="target-affects-type">{{ localize "ADRASAMEN.TargetType.Label" }}</label>
                    <select id="target-affects-type" name="quadralithe.effects.target.affects.type">
                        <option value="ally" {{#if (eq system.quadralithe.effects.target.affects.type "ally"
                            )}}selected{{/if}}>
                            {{ localize "ADRASAMEN.TargetType.Ally" }}
                        </option>
                        <option value="enemy" {{#if (eq system.quadralithe.effects.target.affects.type "enemy"
                            )}}selected{{/if}}>
                            {{ localize "ADRASAMEN.TargetType.Enemy" }}
                        </option>
                        <option value="any" {{#if (eq system.quadralithe.effects.target.affects.type "any"
                            )}}selected{{/if}}>
                            {{ localize "ADRASAMEN.TargetType.Any" }}
                        </option>
                    </select>
                </div>

                <div class="form-group">
                    <label for="target-affects-count">{{ localize "ADRASAMEN.TargetCount" }}</label>
                    <input type="text" id="target-affects-count" name="quadralithe.effects.target.affects.count"
                        value="{{system.quadralithe.effects.target.affects.count}}" placeholder="1" />
                </div>

                <div class="form-group form-checkbox">
                    <input type="checkbox" id="target-affects-choice" name="quadralithe.effects.target.affects.choice"
                        {{#if system.quadralithe.effects.target.affects.choice}}checked{{/if}} />
                    <label for="target-affects-choice">{{ localize "ADRASAMEN.TargetChoice" }}</label>
                </div>
            </div>

            <div class="target-template">
                <h5>{{ localize "ADRASAMEN.TargetTemplate" }}</h5>

                <div class="form-group">
                    <label for="target-template-type">{{ localize "ADRASAMEN.TemplateType.Label" }}</label>
                    <select id="target-template-type" name="quadralithe.effects.target.template.type">
                        <option value="" {{#unless system.quadralithe.effects.target.template.type}}selected{{/unless}}>
                            {{ localize "ADRASAMEN.None" }}
                        </option>
                        <option value="circle" {{#if (eq system.quadralithe.effects.target.template.type "circle"
                            )}}selected{{/if}}>
                            {{ localize "ADRASAMEN.TemplateType.Circle" }}
                        </option>
                        <option value="cone" {{#if (eq system.quadralithe.effects.target.template.type "cone"
                            )}}selected{{/if}}>
                            {{ localize "ADRASAMEN.TemplateType.Cone" }}
                        </option>
                        <option value="line" {{#if (eq system.quadralithe.effects.target.template.type "line"
                            )}}selected{{/if}}>
                            {{ localize "ADRASAMEN.TemplateType.Line" }}
                        </option>
                        <option value="rect" {{#if (eq system.quadralithe.effects.target.template.type "rect"
                            )}}selected{{/if}}>
                            {{ localize "ADRASAMEN.TemplateType.Rect" }}
                        </option>
                    </select>
                </div>

                <div class="form-group">
                    <label for="target-template-size">{{ localize "ADRASAMEN.TemplateSize" }}</label>
                    <input type="text" id="target-template-size" name="quadralithe.effects.target.template.size"
                        value="{{system.quadralithe.effects.target.template.size}}" placeholder="0" />
                </div>

                <div class="form-group form-checkbox">
                    <input type="checkbox" id="target-template-contiguous"
                        name="quadralithe.effects.target.template.contiguous" {{#if
                        system.quadralithe.effects.target.template.contiguous}}checked{{/if}} />
                    <label for="target-template-contiguous">{{ localize "ADRASAMEN.TemplateContiguous" }}</label>
                </div>
            </div>
        </fieldset>
    </div>
    {{/if}}
</div>